local function addLog(msg, color)
    local t = Instance.new("TextLabel", logFrame)
    t.BackgroundTransparency = 1
    t.Size = UDim2.new(1, 0, 0, 16)
    t.Font = Enum.Font.Code
    t.Text = "> " .. msg
    t.TextColor3 = color or Color3.fromRGB(180, 180, 180)
    t.TextSize = 10
    t.TextXAlignment = Enum.TextXAlignment.Left
    logFrame.CanvasPosition = Vector2.new(0, logFrame.AbsoluteCanvasSize.Y)
end

-- LÓGICA DE BÚSQUEDA AVANZADA (HUNTER)
local function ServerHop()
    addLog("Escaneando servidores...", Color3.fromRGB(255, 255, 0))
    local url = "https://games.roblox.com"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
    local success, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    
    if success and result.data then
        for _, server in pairs(result.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                addLog("Saltando a: " .. server.id:sub(1,8), Color3.fromRGB(0, 255, 100))
                TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id)
                return
            end
        end
    else
        addLog("Error al escanear, reintentando...", Color3.fromRGB(255, 0, 0))
    end
end

huntButton.MouseButton1Click:Connect(ServerHop)

