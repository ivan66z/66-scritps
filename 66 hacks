if _G.AutoJoiner66Loaded then 
    print("66 Auto Joiner ya estaba activo.")
    return 
end
_G.AutoJoiner66Loaded = true

local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local VirtualUser = game:GetService("VirtualUser")

print("----------------------------")
print("66 Auto Joiner Activado")
print("Monitoreando conexión...")
print("----------------------------")

-- 1. FUNCIÓN ANTI-AFK (Evita que te saquen a los 20 min)
Players.LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
    print("66: Movimiento Anti-AFK ejecutado.")
end)

-- 2. FUNCIÓN DE RECONEXIÓN (Auto Joiner)
GuiService.ErrorMessageChanged:Connect(function()
    local mensajeError = GuiService:GetErrorMessage()
    if mensajeError ~= "" then
        print("66: Error detectado: " .. mensajeError)
        print("66: Intentando re-unirse en 5 segundos...")
        
        task.wait(5) -- Tiempo de espera para evitar errores de servidor lleno
        
        -- Intentar unirse a un servidor nuevo
        TeleportService:Teleport(game.PlaceId, Players.LocalPlayer)
    end
end)

-- 3. COMANDO DE SEGURIDAD (Si el juego se cierra solo)
-- Algunos executors requieren este bucle para errores fatales
spawn(function()
    while task.wait(10) do
        if not game:IsLoaded() then
            TeleportService:Teleport(game.PlaceId, Players.LocalPlayer)
        end
    end
end)
